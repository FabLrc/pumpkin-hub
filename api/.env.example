# ============================================================
# Pumpkin Hub API — Variables d'environnement
# Copier ce fichier en .env pour le développement local.
# ============================================================

# --- Serveur ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000

# --- Base de données ---
DATABASE_URL=postgres://pumpkin_user:dev_password@localhost:5432/pumpkin_hub_dev

# --- Meilisearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=dev_master_key

# --- Logging ---
# Exemple : pumpkin_hub_api=debug,tower_http=info
RUST_LOG=pumpkin_hub_api=info,tower_http=debug
