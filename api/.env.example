# ============================================================
# Pumpkin Hub API — Variables d'environnement
# Copier ce fichier en .env pour le développement local.
# ============================================================

# --- Serveur ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Origines CORS autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:3000

# --- Base de données ---
DATABASE_URL=postgres://pumpkin_user:dev_password@localhost:5432/pumpkin_hub_dev

# --- Meilisearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=dev_master_key

# --- GitHub OAuth ---
# Créer une OAuth App sur https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/github/callback

# --- JWT ---
# Clé secrète pour signer les tokens (changer impérativement en production)
JWT_SECRET=dev_jwt_secret_change_me_in_production
JWT_TTL_SECONDS=86400

# --- SMTP Email (optionnel — omit pour désactiver l'envoi d'email) ---
# Configuration pour l'envoi d'emails (verification & password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_ADDRESS=noreply@pumpkin-hub.io

# --- Logging ---
# Exemple : pumpkin_hub_api=debug,tower_http=info
RUST_LOG=pumpkin_hub_api=info,tower_http=debug
