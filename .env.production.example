# ============================================================
#  Pumpkin Hub — Variables d'environnement de PRODUCTION
#  Copier ce fichier vers .env et renseigner toutes les valeurs.
#  Ne jamais commiter le .env réel dans le dépôt.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=pumpkin
POSTGRES_PASSWORD=CHANGEME_strong_password_here
POSTGRES_DB=pumpkin_hub

# ── Meilisearch ──────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
MEILISEARCH_KEY=CHANGEME_meilisearch_master_key

# ── JWT ──────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=CHANGEME_jwt_secret_at_least_32_chars

# ── OAuth — GitHub ───────────────────────────────────────────
# Créer sur https://github.com/settings/applications/new
# Callback URL : https://api.pumpkinhub.org/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth — Discord ──────────────────────────────────────────
# Créer sur https://discord.com/developers/applications
# Redirect URI : https://api.pumpkinhub.org/api/v1/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── OAuth — Google (désactivé pour l'instant) ────────────────
# Créer sur https://console.cloud.google.com/apis/credentials
# Redirect URI : https://api.pumpkinhub.org/api/v1/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Cloudflare R2 ────────────────────────────────────────────
# Tableau de bord R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=pumpkin-hub-binaries

# ── Domaine custom R2 (RECOMMANDÉ pour la production) ────────
# Dashboard Cloudflare R2 → bucket → Settings → Custom Domains → Connect Domain
# Pointer un sous-domaine (ex: assets.pumpkinhub.org) vers le bucket.
# Avantages : CDN Cloudflare, cache, sans rate-limit, sans expiration.
# NE PAS utiliser l'URL r2.dev (rate-limited, non recommandée en production).
# IMPORTANT : inclure le schéma https:// — ex: https://r2.pumpkinhub.org
R2_PUBLIC_URL=https://r2.pumpkinhub.org
# Activer les URLs directes via le domaine custom (désactiver le presigning pour les icônes/médias).
# Les téléchargements de binaires utilisent toujours des URLs présignées via l'API S3 R2.
S3_USE_DIRECT_URLS=true

# ── Email — Resend ───────────────────────────────────────────
# Clé API sur https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXX
# Domaine vérifié dans Resend (https://resend.com/domains)
SMTP_FROM_ADDRESS=noreply@pumpkinhub.org

# ── GitHub App (optionnel) ───────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
